{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BankSimulator": {
    "BaseUrl": "http://localhost:8080",
    "TimeoutSeconds": 10,
    "RetryCount": 3,
    "RetryDelayMs": 200,
    "CircuitBreakerFailureThreshold": 5,
    "CircuitBreakerOpenSeconds": 30
  },
  "Hmac": {
    "SecretKey": "super-secret-hmac-key-change-in-production"
  },
  "Jwt": {
    "Issuer": "payment-gateway",
    "Audience": "merchants",
    "SecretKey": "super-secret-jwt-key-change-in-production-min-32-chars",
    "ExpiryMinutes": 60
  },
  "AllowedHosts": "*"
}